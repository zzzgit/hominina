{
	"env": {
		"browser": false,
		"commonjs": true,
		"es6": true,
		"node": true,
		"mocha": true
	},
	"parserOptions": {
		"ecmaVersion": 2018,
		"ecmaFeatures": {
			"jsx": true
		},
		"sourceType": "module"
	},
	"extends": [
		"janus/js" 
	],
	
	"rules": {
		"valid-typeof": "warn",
		"promise/catch-or-return": ["error"]
	}
}
